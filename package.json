{
  "name": "krawl",
  "version": "1.0.0",
  "description": "Knowledge Retrieval and Web Logic Engine",
  "type": "module",
  "bin": {
    "krawl": "./krawl.ts"
  },
  "scripts": {
    "start": "tsx krawl.ts",
    "dev": "tsx watch krawl.ts",
    "mcp": "tsx src/mcp/http-server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts --ignore-pattern dist --ignore-pattern node_modules",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:smoke": "vitest run tests/smoke",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "p-limit": "latest",
    "pdf-parse": "latest",
    "playwright": "latest",
    "undici": "^6",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "latest",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "@types/pdf-parse": "latest",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
