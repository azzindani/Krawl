# Krawl — environment template. Copy to `.env` and edit.
#   cp .env.example .env
#
# Anything left commented out falls back to the default printed in the comment.

# ─── Container role ─────────────────────────────────────────────────────────
# mcp      → MCP HTTP server on :KRAWL_PORT (default — public deploy)
# loop     → run KRAWL_TASKS, sleep KRAWL_INTERVAL_SECONDS, repeat forever
# once     → run KRAWL_TASKS once, exit (host-cron / k8s Job)
# query    → one-shot SQL (requires KRAWL_QUERY)
# stats    → one-shot --stats
# export   → one-shot --export $KRAWL_EXPORT_TARGET (default: all)
# shell    → drop to bash (debug)
KRAWL_MODE=mcp

# Skip the vitest unit suite during `docker build` (passes --build-arg).
# Set to 0 to enforce a green test run before the image is produced.
KRAWL_SKIP_TESTS=1

# ─── MCP server ─────────────────────────────────────────────────────────────
# Internal port — what the MCP HTTP server binds inside the container.
# Leave at 3333 unless you have a reason to change it.
KRAWL_PORT=3333

# Host-side debug port — only published on 127.0.0.1 so the shared caddy-router
# (which reaches the container by name on krawl_net) doesn't need it. Change
# only if 3344 collides with something else on the host.
KRAWL_HOST_PORT=3344

# ─── Task input (loop/once modes) ───────────────────────────────────────────
# Path inside the container — ./tasks is bind-mounted at /tasks read-only.
KRAWL_TASKS=/tasks/financial.json

# ─── Loop cadence ───────────────────────────────────────────────────────────
# Seconds between runs in KRAWL_MODE=loop. Defaults to 6 hours.
# Examples:  3600 = hourly · 21600 = 6h · 86400 = daily
KRAWL_INTERVAL_SECONDS=21600

# ─── Concurrency knobs ──────────────────────────────────────────────────────
# Tune to the VPS: a 1 vCPU / 2 GB box should keep these low.
KRAWL_HTTP_CONCURRENCY=5
KRAWL_BROWSER_CONTEXTS=3

# ─── Maintenance (loop mode + KRAWL_MODE=maintenance) ──────────────────────
# Rotate krawl_output.jsonl → .gz when it crosses this size. Default 100 MB.
KRAWL_JSONL_ROTATE_BYTES=104857600
# SQLite VACUUM cadence in seconds — defrags + reclaims space. Default 24 h.
# Tracked via .last_vacuum in the data dir so back-to-back loop iterations
# don't redo it. VACUUM rewrites the whole DB; don't set this absurdly low.
KRAWL_VACUUM_INTERVAL_SECONDS=86400

# ─── Auth (pick ONE) ────────────────────────────────────────────────────────
# Priority at startup: KRAWL_TOKENS_FILE > KRAWL_TOKENS > KRAWL_API_KEY.
# With none of the three set the server runs UNAUTHENTICATED — only do
# that on a private network / behind a firewall.
#
# 1. Multi-token from file (recommended for production):
#    Mount a JSON file like { "claude-desktop": "sk-...", "hermes": "sk-..." }
#    docker-compose.yml mounts ./tokens.json into the container at this path:
# KRAWL_TOKENS_FILE=/home/pwuser/tokens.json
#
# 2. Multi-token inline (good for env-only deployments — no file mount):
# KRAWL_TOKENS=claude-desktop:sk-aaaa,hermes:sk-bbbb
#
# 3. Single shared key (simplest):
KRAWL_API_KEY=sk-replace-me-with-a-long-random-string

# ─── Caddy TLS profile only ─────────────────────────────────────────────────
# Required for `docker compose --profile tls up`. Set both, then point your
# DNS A record at the VPS IP.
KRAWL_DOMAIN=krawl.casava.space
KRAWL_ACME_EMAIL=422indani@gmail.com

# ─── Files browser HTTP Basic Auth (REQUIRED for TLS profile) ───────────────
# Browser login in front of the /files CSV directory listing. /mcp keeps its
# own Bearer auth, /health stays public. The Caddyfile's basicauth block
# hard-requires these — leave blank and Caddy will refuse to start.
# To disable entirely, delete the `basicauth { ... }` block in caddy/Caddyfile.
# Generate a hash:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-pass'
# Then escape every `$` as `$$` in the line below (docker compose substitution).
KRAWL_BASIC_USER=admin
KRAWL_BASIC_HASH=

# ─── One-shot mode inputs (ignored in mcp/loop modes) ───────────────────────
# Only consumed by KRAWL_MODE=query / export.
# KRAWL_QUERY=SELECT COUNT(*) FROM pages
# KRAWL_EXPORT_TARGET=all
